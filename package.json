{
  "name": "landmark-smart-route-planner-root",
  "version": "1.0.0",
  "description": "Root orchestration for Landmark Smart Route Planner",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "db:start": "start \"MongoDB\" /MIN \"C:\\Program Files\\MongoDB\\Server\\8.2\\bin\\mongod.exe\" --dbpath \"%USERPROFILE%\\mongodb-data\" --logpath \"%USERPROFILE%\\mongodb-data\\mongod.log\" --logappend --port 27017 --bind_ip 127.0.0.1",
    "dev:full": "start.bat",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "npm --prefix backend start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
